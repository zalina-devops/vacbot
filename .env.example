# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/vacbot

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(16))")
SECRET_KEY=your-secret-key-here

# SuperJob API token (get at api.superjob.ru)
SUPERJOB_TOKEN=v3.r2.your_superjob_token_here

# OpenRouter API key (get at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw

# Optional: proxy for Telegram (if needed)
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:10808

# Parser settings
PARSING_INTERVAL_HOURS=24
AUTO_PARSE_ON_START=True